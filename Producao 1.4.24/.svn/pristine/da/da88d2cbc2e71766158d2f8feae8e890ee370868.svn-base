package br.gov.mt.sefaz.itc.integracao;

public class VerificarValidadeGiaItcdPorNumeroVO
{

   private boolean isValido;
   private String msgErro;
   
   public VerificarValidadeGiaItcdPorNumeroVO()
   {
   }
   
   public VerificarValidadeGiaItcdPorNumeroVO(boolean isValido, String msgErro)
   {
      this.setValido(isValido);
      this.setMsgErro(msgErro);
   }

   public boolean isValido()
   {
      return isValido;
   }

   public void setValido(boolean valido)
   {
      isValido = valido;
   }

   public String getMsgErro()
   {
      return msgErro;
   }

   public void setMsgErro(String msgErro)
   {
      this.msgErro = msgErro;
   }
}