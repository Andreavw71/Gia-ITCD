package br.gov.mt.sefaz.itc.model.tabelabasica.parametrosdalegislacao;

/**
 * Referencia ‡ Chave Prim·ria de uma AlÌquota (Tabela ITCTB11_LGIL_ALIQUOTA)
 * @author Daniel Balieiro
 * @version $Revision: 1.1.1.1 $
 */
public class AliquotaPk
{
	/**
	 * Chave Prim·ria
	 * @implemented by Daniel Balieiro
	 */
	private long codigo;

	/**
	 * Construtor Padr„o (Vazio)
	 * @implemented by Daniel Balieiro
	 */
	public AliquotaPk()
	{
	}

	/**
	 * Construtor que recebe a Chave Prim·ria como parametro
	 * @param codigo Chave Prim·ria
	 * @implemented by Daniel Balieiro
	 */
	public AliquotaPk(long codigo)
	{
		setCodigo(codigo);
	}

	/**
	 * MÈtodo que altera a Chave Prim·ria
	 * @param codigo Chave Prim·ria
	 * @implemented by Daniel Balieiro
	 */
	public void setCodigo(long codigo)
	{
		this.codigo = codigo;
	}

	/**
	 * MÈtodo que retorna a Chave Prim·ria	
	 * @return long - Chave Prim·ria
	 * @implemented by Daniel Balieiro
	 */
	public long getCodigo()
	{
		return codigo;
	}
}
