package br.gov.mt.sefaz.itc.model.generico.avaliacao;

/**
 * Classe que representa a chave primaria da tabela de Avaliação de Bem Tributável
 * @author Daniel Balieiro
 * @version $Revision: 1.1.1.1 $
 */
public class AvaliacaoBemTributavelPk
{
	private long codigo;

	/**
	 * Método que recebe a Avaliação do Bem Tributavel
	 *
	 * @param codigo
	 * @implemented by Daniel Balieiro
	 */
	public AvaliacaoBemTributavelPk(long codigo)
	{
		setCodigo(codigo);
	}

	/**
	 * Método para atribuir a Chave Primária
	 *
	 * @param codigo
	 * @implemented by Daniel Balieiro
	 */
	public void setCodigo(long codigo)
	{
		this.codigo = codigo;
	}

	/**
	 * Método que retorna a Chave Primária
	 *
	 * @return
	 * @implemented by Daniel Balieiro
	 */
	public long getCodigo()
	{
		return codigo;
	}
}
