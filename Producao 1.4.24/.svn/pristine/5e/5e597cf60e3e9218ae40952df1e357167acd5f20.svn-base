package br.gov.mt.sefaz.itc.util.excecoes;

public class DoacaoSucessivaNaoPermitidaException extends RuntimeException {
    
    public DoacaoSucessivaNaoPermitidaException() {
        super();
    }
    
    public DoacaoSucessivaNaoPermitidaException(String message) {
        super(message);
    }
    
    public DoacaoSucessivaNaoPermitidaException(Throwable cause) {
        super(cause);
    }
    
    public DoacaoSucessivaNaoPermitidaException(String message, Throwable cause) {
        super(message, cause);
    }    
}
