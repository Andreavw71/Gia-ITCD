package br.gov.mt.sefaz.itc.model.giaitcd.giaitcddoacao.beneficiario.doacaosucessiva;



/**
 * Classe de Chave Prim·ria de um GIA ITCD.
 * @author Daniel Balieiro
 * @version $Revision: 1.1.1.1 $
 */
public class GIAITCDDoacaoSucessivaPk
{
	private long codigo;

	public GIAITCDDoacaoSucessivaPk()
	{
	}

	public GIAITCDDoacaoSucessivaPk(long codigo)
	{
		setCodigo(codigo);
	}

	public void setCodigo(long codigo)
	{
		this.codigo = codigo;
	}


	public long getCodigo()
	{
		return codigo;
	}
}
