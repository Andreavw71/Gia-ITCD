package br.gov.mt.sefaz.itc.model.giaitcd.fichaimovelurbano;

/**
 * Classe que representa a Pk da tabela
 * @author Lucas Nascimento
 * @version $Revision: 1.1.1.1 $
 */
public class FichaImovelUrbanoPk
{
	private long codigo;

	/**
	 * Contrutor padrăo que recebe o código da Pk
	 * @param codigo
	 * @implemented by Lucas Nascimento
	 */
	public FichaImovelUrbanoPk(long codigo)
	{
		setCodigo(codigo);
	}

	/**
	 * Retorna o código da Pk
	 * @return long
	 * @implemented by Lucas Nascimento
	 */
	public long getCodigo()
	{
		return codigo;
	}

	/**
	 * Atribui o código a Pk
	 * @param codigo
	 * @implemented by Lucas Nascimento
	 */
	public void setCodigo(long codigo)
	{
		this.codigo = codigo;
	}
}
