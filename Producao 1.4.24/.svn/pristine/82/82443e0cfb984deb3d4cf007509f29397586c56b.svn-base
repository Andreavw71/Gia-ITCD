package br.gov.mt.sefaz.itc.model.tabelabasica.cultura;

/**
 * Referencia ŕ Chave Primaria de uma CULTURA (Tabela ITCTB08_CULTURA)
 * @author Marlo Eichenberg Motta
 * @version $Revision: 1.1.1.1 $
 */
public class CulturaPk
{
	private long codigo;

	/**
	 * Construtor vazio.
	 * @implemented by Marlo Eichenberg Motta
	 */
	public CulturaPk()
	{
	}

	/**
	 * Construtor da classe.
	 * @param codigo Chave Primária
	 * @implemented by Marlo Eichenberg Motta
	 */
	public CulturaPk(long codigo)
	{
		super();
		setCodigo(codigo);
	}

	/**
	 * Retorna o código (chave primária).
	 * @param codigo
	 * @implemented by Marlo Eichenberg Motta
	 */
	public void setCodigo(long codigo)
	{
		this.codigo = codigo;
	}

	/**
	 * Atrobui um código (chave primária).
	 * @return
	 * @implemented by Marlo Eichenberg Motta
	 */
	public long getCodigo()
	{
		return codigo;
	}

	/**
	 * Retorna a chave primária (PK).
	 * @return
	 * @implemented by Marlo Eichenberg Motta
	 */
	public CulturaPk setPk()
	{
		return new CulturaPk(getCodigo());
	}
}
