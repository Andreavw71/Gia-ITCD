          listaDePermissoes.put(CODIGO_ALTERAR_CRITERIO_MUNICIPIO, new FormAcessoBean(CODIGO_ALTERAR_CRITERIO_MUNICIPIO, PERMISSAO_ALTERAR_CRIMUNI, getContexto() + 
