package br.gov.mt.sefaz.itc.model.tabelabasica.basecalculoimovelrural;

public class BaseCalculoImovelRuralPk
{
   private long codigo;

   public BaseCalculoImovelRuralPk()
   {
   }

   public BaseCalculoImovelRuralPk(long codigo)
   {
      super();
      setCodigo(codigo);
   }

   public void setCodigo(long codigo)
   {
      this.codigo = codigo;
   }

   public long getCodigo()
   {
      return codigo;
   }

   public BaseCalculoImovelRuralPk getPk()
   {
      return new BaseCalculoImovelRuralPk(getCodigo());
   }
}
