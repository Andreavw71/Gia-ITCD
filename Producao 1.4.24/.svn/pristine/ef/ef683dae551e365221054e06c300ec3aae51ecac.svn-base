package br.gov.mt.sefaz.itc.util.log;

import sefaz.mt.util.SefazDataHora;


public class ExibirLOG
{
   public ExibirLOG()
   {
   }
   
   
   /**
    * Este mÈtodo tem por objetivo Exibir a mensagem no console de LOG.
    * 
    * @param msg
    */
   public static void exibirLogSimplificado(CharSequence msg)
   {
      System.out.println("| "+SefazDataHora.getDataHoraAtual().toString() +" | "+msg);
   }
   
   /**
    * Este mÈtodo tem por objetivo Exibir a mensagem no console de LOG.
    * 
    * @param msg
    */
   public static void exibirLog(CharSequence msg)
   {
      System.out.println("------------------------------------------------------------------------------------------------------");
      System.out.println("| "+SefazDataHora.getDataHoraAtual().toString() +" | "+msg);
      System.out.println("------------------------------------------------------------------------------------------------------");
   }
   
   /**
    * Este mÈtodo tem por objetivo Exibir a mensagem no console de LOG.
    * 
    * @param msg
    */
   public static void exibirLog(CharSequence msg, long codigoGIA)
   {
      System.out.println("--------------------------------| LOG - GIA - "+codigoGIA+" |----------------------------------------");
      System.out.println("| "+SefazDataHora.getDataHoraAtual().toString() +" | "+msg);
      System.out.println("------------------------------------------------------------------------------------------------------");
   }
   
}
